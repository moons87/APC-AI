# Скопируйте в .env и заполните: cp .env.example .env
# В этом файле должны быть ТОЛЬКО заглушки — никаких реальных ключей.

# --- Обязательно ---
# Ключ Anthropic API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# --- Опционально ---
# Модель Claude для анализа
ANTHROPIC_MODEL=claude-sonnet-4-6

# Токен HuggingFace для диаризации pyannote.
# Нужно принять условия моделей:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
# Без токена приложение работает, но БЕЗ разделения говорящих.
HF_TOKEN=

# Параметры Whisper
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# URL бэкенда для браузера (меняйте при деплое на сервер)
VITE_API_URL=http://localhost:8000

# CORS (через запятую). По умолчанию разрешено всё — для MVP.
CORS_ORIGINS=*

# Мягкий лимит размера загружаемого файла в МБ (видео бывают крупными).
MAX_UPLOAD_MB=2048
